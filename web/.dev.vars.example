# Cloudflare Pages 로컬 개발용 환경변수 예시
# 실제 값을 .dev.vars 에 채워 사용 (이 파일은 git에 커밋됨, .dev.vars 는 무시됨)
# wrangler pages dev 가 자동으로 로드

# 백엔드 API
NEXT_PUBLIC_API_BASE_URL=https://api.insight.taeannews.co.kr

# Mock 모드 (백엔드 미연결 시 화면 검증용)
NEXT_PUBLIC_USE_MOCK=true

# Web Push VAPID 공개키 (서버에서 발급)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# 인증 (NextAuth 등 도입 시)
# AUTH_SECRET=
# AUTH_TAEAN_SSO_CLIENT_ID=
# AUTH_TAEAN_SSO_CLIENT_SECRET=

# LLM API (서버사이드만 — 절대 NEXT_PUBLIC_ 접두사 금지)
# ANTHROPIC_API_KEY=sk-ant-...
# TOGETHER_API_KEY=...

# Toss Payments
# TOSS_PAYMENTS_CLIENT_KEY=
# TOSS_PAYMENTS_SECRET_KEY=
