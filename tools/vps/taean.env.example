# 태안 크롤러 통합 환경변수 — /etc/taean.env 로 복사 후 값 채우기 (chmod 600).
# echotwin 등 다른 프로젝트와 공존: 이 파일은 태안 전용, systemd EnvironmentFile로만 사용.

# 군청·CCTV 적재 인증(= Worker GOV_IMPORT_TOKEN 과 동일)
TAEAN_GOV_TOKEN=
# ITS 국가교통정보센터 인증키(도로 CCTV)
ITS_API_KEY=
# 적재 대상 Worker(기본값이면 생략 가능)
TAEAN_API=https://taean-insight-api.chs9182.workers.dev

# ── 팟캐스트·기사낭독(Gemini) — 한국 IP 필요 ──
# Gemini 키(무료 등급 권장). 기사낭독은 여러 키 로테이션 원하면 tools/news-audio/.gemini_keys 파일 사용.
GEMINI_API_KEY=

# D1 조회·R2 업로드용 Cloudflare 인증(wrangler가 이 값으로 헤드리스 동작)
#   대시보드 → My Profile → API Tokens → D1 Edit + R2 Edit 권한 토큰 생성
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
